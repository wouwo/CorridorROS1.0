<?xml version="1.0" ?>
<sdf version="1.5">
      <world name="default">
      <include><uri>model://ground_plane</uri></include>
      <include><uri>model://sun</uri></include>
        

    <model name='wall_line_1'>
      <static>1</static>
      <link name='link'>
    
	  <pose frame=''>0.0 -10.0 1.4 0 0 0.0</pose>

        <collision name='collision'>
          <geometry>
            <box>
	     <size> 40.0 0.2 2.8 </size>

            </box>
          </geometry>
        </collision>
    

        <visual name='visual'>
          <cast_shadows>0</cast_shadows>
          <geometry>
            <box>
	     <size> 40.0 0.2 2.8 </size>

            </box>
          </geometry>
          <material>
            <script>
              <uri>model://grey_wall/materials/scripts</uri>
              <uri>model://grey_wall/materials/textures</uri>
              <name>vrc/grey_wall</name>
            </script>
          </material>
        </visual>
      </link>
    </model>
    

    <model name='wall_line_2'>
      <static>1</static>
      <link name='link'>
    
	  <pose frame=''>0.0 10.0 1.4 0 0 0.0</pose>

        <collision name='collision'>
          <geometry>
            <box>
	     <size> 40.0 0.2 2.8 </size>

            </box>
          </geometry>
        </collision>
    

        <visual name='visual'>
          <cast_shadows>0</cast_shadows>
          <geometry>
            <box>
	     <size> 40.0 0.2 2.8 </size>

            </box>
          </geometry>
          <material>
            <script>
              <uri>model://grey_wall/materials/scripts</uri>
              <uri>model://grey_wall/materials/textures</uri>
              <name>vrc/grey_wall</name>
            </script>
          </material>
        </visual>
      </link>
    </model>
    

            <plugin name="ActorPosesPlugin" filename="libActorPosesPlugin.so"></plugin>
      </world>
    </sdf>
